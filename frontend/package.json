{
  "name": "abi-financial-assistant",
  "version": "1.0.0",
  "main": "electron/main.js",
  "author": "Abi Team",
  "description": "Privacy-first AI Financial Assistant for Actual Budget",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "wait-on tcp:5173 && electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "dist": "npm run build && electron-builder --win --x64 && node -e \"const {rcedit} = require('rcedit'); rcedit('dist-electron/win-unpacked/Abi Financial Assistant.exe', {'icon': 'electron/icon.ico'}).then(() => console.log('Icon embedded!')).catch(e => console.error(e))\" && npx electron-builder --win --x64 --prepackaged dist-electron/win-unpacked",
    "dist:dir": "npm run build && electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.abi.financial-assistant",
    "productName": "Abi Financial Assistant",
    "icon": "electron/icon.ico",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/abi_backend.exe",
        "to": "backend/abi_backend.exe"
      },
      {
        "from": "../bridge/",
        "to": "bridge/",
        "filter": [
          "**/*",
          "!temp-cache/**",
          "!temp-write-cache/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup.${ext}",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico"
    }
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
