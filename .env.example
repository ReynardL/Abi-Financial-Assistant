# Abi Financial Assistant - Configuration Template
# Copy this file to .env and fill in your values

# ==== AI Provider ====
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Leave empty for OpenAI, or set for local LLMs (e.g., http://localhost:11434/v1)
OPENAI_BASE_URL=

# ==== Actual Budget ====
# Your Actual Budget server URL (default local instance)
ACTUAL_SERVER_URL=http://localhost:5006
# The password for your budget file
ACTUAL_PASSWORD=your_actual_password_here
# Find your Sync ID in Actual Budget: Settings > Show advanced settings > Sync ID
ACTUAL_SYNC_ID=your_sync_id_here
